<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <style>
      :root {
        --primary: {{brand.primaryColor}};
        --accent: {{brand.accentColor}};
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 1080px; height: 1350px; }
      body {
        font-family: '{{brand.typography.body}}', system-ui, sans-serif;
        background: var(--primary);
        color: #fff;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
      }
      .photo { position: absolute; inset: 0; object-fit: cover; width: 100%; height: 70%; }
      .content { position: relative; padding: 64px; background: linear-gradient(transparent, var(--primary) 35%); }
      .headline { font-family: '{{brand.typography.heading}}', sans-serif; font-size: 84px; font-weight: 800; line-height: 1.05; }
      .cta { display: inline-block; margin-top: 32px; padding: 24px 48px; background: var(--accent); color: var(--primary); font-size: 40px; font-weight: 700; border-radius: 16px; }
      .price { font-size: 56px; font-weight: 700; margin-top: 16px; }
      .disclaimer { font-size: 20px; opacity: 0.7; margin-top: 24px; }
    </style>
  </head>
  <body>
    {{#if photoUrl}}<img class="photo" src="{{photoUrl}}" alt="" />{{/if}}
    <div class="content">
      <h1 class="headline">{{headline}} {{emoji}}</h1>
      {{#if price}}<div class="price">{{price}}</div>{{/if}}
      <span class="cta">{{cta}}</span>
      {{> disclaimer}}
    </div>
  </body>
</html>
