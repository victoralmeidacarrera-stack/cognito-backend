<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <style>
      {{{layout.fontsImport}}}
      :root {
        --primary: {{brand.primaryColor}};
        --accent: {{brand.accentColor}};
        --text: {{layout.textColor}};
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 1080px; height: 1350px; }
      body {
        font-family: '{{layout.bodyFont}}', system-ui, sans-serif;
        background: var(--primary);
        color: var(--text);
        position: relative;
      }
      .photo { position: absolute; inset: 0; object-fit: cover; width: 100%; height: 100%; }
      .content {
        position: absolute; inset: 0; padding: 72px;
        display: flex; flex-direction: column;
        justify-content: {{layout.justify}};
        align-items: {{layout.items}};
        text-align: {{layout.textAlign}};
        background: {{{layout.overlayCss}}};
      }
      .headline { font-family: '{{layout.headlineFont}}', sans-serif; font-size: {{layout.headlineSize}}px; font-weight: 800; line-height: 1.05; max-width: 90%; }
      .price { font-size: {{layout.priceSize}}px; font-weight: 700; margin-top: 16px; }
      .cta { display: inline-block; margin-top: 32px; padding: 24px 48px; background: var(--accent); color: var(--primary); font-size: {{layout.ctaSize}}px; font-weight: 700; border-radius: 16px; }
      .sub { font-size: {{layout.bodySize}}px; margin-top: 12px; opacity: 0.92; max-width: 88%; }
      .disclaimer { font-size: 20px; opacity: 0.7; margin-top: 24px; }
    </style>
  </head>
  <body>
    {{#if photoUrl}}<img class="photo" src="{{photoUrl}}" alt="" />{{/if}}
    <div class="content">
      <h1 class="headline">{{headline}} {{emoji}}</h1>
      {{#if sub_headline}}<div class="sub">{{sub_headline}}</div>{{/if}}
      {{#if price}}<div class="price">{{price}}</div>{{/if}}
      <span class="cta">{{cta}}</span>
      {{> disclaimer}}
    </div>
  </body>
</html>
