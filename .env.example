# ──────────────────────────────────────────────
# Cognito AI backend — variáveis de ambiente
# Copie para .env e preencha. Validado por zod em src/config/env.ts
# ──────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=debug

# CORS: origens permitidas separadas por vírgula (ex.: https://app.cognito.ai).
# Vazio em dev = reflete a origem da requisição.
CORS_ORIGINS=

# Database (Postgres local via docker-compose / Neon em prod)
DATABASE_URL=postgresql://cognito:cognito@localhost:5432/cognito?schema=public

# Redis (BullMQ) — local via docker-compose / Upstash em prod
REDIS_URL=redis://localhost:6379

# ── IA de copy ─────────────────────────────────
# Provedor: 'anthropic' (default) ou 'openai' — qualquer API compatível com
# OpenAI chat/completions (OpenAI, DeepSeek, Groq, Gemini, Ollama local...).
COPY_PROVIDER=anthropic

# Só para COPY_PROVIDER=openai (exemplos: https://api.deepseek.com/v1 +
# deepseek-chat · https://api.groq.com/openai/v1 + llama-3.3-70b-versatile ·
# http://localhost:11434/v1 + llama3 no Ollama, sem LLM_API_KEY):
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Só para COPY_PROVIDER=anthropic:
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL_BRIEFING=claude-sonnet-4-5
ANTHROPIC_MODEL_VARIATIONS=claude-haiku-4-5-20251001

# ── IA de imagem (fundo dos criativos) ─────────
# fal.ai — Flux 1.1 Pro. O prompt do fundo é montado em
# src/modules/backgrounds/background-prompt.ts e pode ser sobrescrito aqui
# ({vehicle} é substituído pela descrição do veículo):
FAL_API_KEY=
FLUX_BACKGROUND_PROMPT=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cognito-creatives
R2_PUBLIC_URL=https://cdn.example.com

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM=Cognito AI <no-reply@cognito.ai>

# Clerk (auth)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Auth: bypass do Clerk em dev (resolve a org/admin demo ou os headers
# x-dev-user-id / x-dev-org-id). Forçado off em produção. Default: true em dev.
AUTH_DEV_BYPASS=true

# Puppeteer: caminho do Chromium em prod (Railway). Vazio = bundled.
PUPPETEER_EXECUTABLE_PATH=

# Sentry (observabilidade) — opcional em dev
SENTRY_DSN=
